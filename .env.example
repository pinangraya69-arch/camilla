# Camilla — Self-Learning Meteora LP Agent

# ─── Required ──────────────────────────────────────────────────────
WALLET_PRIVATE_KEY=your_base58_private_key
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_API_KEY=your_helius_api_key
OPENROUTER_API_KEY=sk-or-...
LLM_MODEL=openrouter/anthropic/claude-3-opus

# ─── Optional ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_CHAT_ID=

# X/Twitter intelligence (Bearer Token from v2 API)
TWITTER_BEARER_TOKEN=AAAAAAAA...

# Discord selfbot (use with caution)
DISCORD_USER_TOKEN=your_user_token
DISCORD_CHANNEL_IDS=channel_id_1,channel_id_2

# Redis (optional, for signal caching)
REDIS_URL=redis://localhost:6379

# ─── API Server (for frontend dashboard integration) ─────────────────────
ENABLE_API=false          # Set to true to start HTTP API server
API_PORT=3001            # Port for API server
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000  # CORS
API_TIMEOUT=30000        # Request timeout in ms (default 30s)

# ─── Runtime ──────────────────────────────────────────────────────
DRY_RUN=true  # Set to false for live trading
